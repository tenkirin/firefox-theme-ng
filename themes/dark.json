{
  "$schema": "vscode://schemas/color-theme",
  "name": "Firefox Dark NG",
  "type": "Dark",
  "tokenColors": [
    {
      "settings": {
        "foreground": "#B1B1B3"
      }
    },
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#939395"
      }
    },
    {
      "name": "String",
      "scope": "string",
      "settings": {
        "foreground": "#709AFF"
      }
    },
    {
      "name": "Regexp",
      "scope": [
        "constant.character.escape.backslash.regexp",
        "constant.other.character-class.regexp",
        "keyword.operator.quantifier.regexp",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#709AFF"
      }
    },
    {
      "name": "Number",
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#709AFF"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "meta.definition.variable.name",
        "support.variable",
        "variable",
        "variable.language"
      ],
      "settings": {
        "foreground": "#75BFFF"
      }
    },
    {
      "name": "Keyword",
      "scope": "keyword",
      "settings": {
        "foreground": "#FF7DE9"
      }
    },
    {
      "name": "Storage",
      "scope": "storage",
      "settings": {
        "foreground": "#FF7DE9"
      }
    },
    {
      "name": "Class name",
      "scope": ["entity.name.class", "entity.name.type"],
      "settings": {
        "foreground": "#B98EFF"
      }
    },
    {
      "name": "Function name",
      "scope": "meta.function-call",
      "settings": {
        "foreground": "#B98EFF"
      }
    },
    {
      "name": "Function definition",
      "scope": "meta.definition.function",
      "settings": {
        "foreground": "#75BFFF"
      }
    },
    {
      "name": "Embedded code markers",
      "scope": [
        "punctuation.section.embedded.begin",
        "punctuation.section.embedded.end"
      ],
      "settings": {
        "foreground": "#E9F4FE"
      }
    },
    {
      "name": "Built-in constant",
      "scope": "constant.language",
      "settings": {
        "foreground": "#E9F4FE"
      }
    },
    {
      "name": "User-defined constant",
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#FFF89E"
      }
    },
    {
      "name": "Inherited class",
      "scope": "entity.other.inherited-class",
      "settings": {
        "foreground": "#B98EFF"
      }
    },
    {
      "name": "Function argument",
      "scope": "variable.parameter",
      "settings": {
        "foreground": "#75BFFF"
      }
    },
    {
      "name": "Storage type",
      "scope": "storage.type",
      "settings": {
        "foreground": "#FF7DE9"
      }
    },
    {
      "name": "Function",
      "scope": "support.function",
      "settings": {
        "foreground": "#B98EFF"
      }
    },
    {
      "name": "Library constant",
      "scope": "support.constant",
      "settings": {
        "foreground": "#709AFF"
      }
    },
    {
      "name": "Library class/type",
      "scope": ["support.type", "support.class"],
      "settings": {
        "foreground": "#B98EFF"
      }
    },
    {
      "name": "Property / Function name",
      "scope": [
        "entity.name.function",
        "support.variable.property.dom",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#86DE74"
      }
    },
    {
      "name": "Object literal key",
      "scope": "meta.object-literal.key",
      "settings": {
        "foreground": "#86DE74"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "meta.brace.round",
        "punctuation.accessor",
        "punctuation.definition.block",
        "punctuation.definition.parameters.begin",
        "punctuation.definition.parameters.end",
        "punctuation.separator.comma",
        "punctuation.separator.key-value",
        "punctuation.terminator.statement"
      ],
      "settings": {
        "foreground": "#D7D7DB"
      }
    },
    {
      "name": "Arrow function",
      "scope": "storage.type.function.arrow.js",
      "settings": {
        "foreground": "#B98EFF"
      }
    },
    {
      "name": "this keyword",
      "scope": "variable.language.this",
      "settings": {
        "foreground": "#FF7DE9"
      }
    },
    {
      "name": "Class types",
      "scope": ["entity.name.type.class", "support.class"],
      "settings": {
        "foreground": "#B98EFF"
      }
    },
    {
      "name": "Assignment operator",
      "scope": "keyword.operator.assignment",
      "settings": {
        "foreground": "#B1B1B3"
      }
    },
    {
      "name": "Tag name",
      "scope": "entity.name.tag",
      "settings": {
        "foreground": "#75BFFF"
      }
    },
    {
      "name": "DOCTYPE",
      "scope": ["meta.tag.metadata.doctype.html", "meta.tag.sgml.doctype.html"],
      "settings": {
        "foreground": "#939395"
      }
    },
    {
      "name": "Tag start/end",
      "scope": "punctuation.definition.tag",
      "settings": {
        "foreground": "#939395"
      }
    },
    {
      "name": "HTML structure tag",
      "scope": "meta.tag.structure.any.html",
      "settings": {
        "foreground": "#B98EFF"
      }
    },
    {
      "name": "Tag attribute",
      "scope": [
        "entity.other.attribute.name",
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.id.html",
        "entity.other.attribute-name.localname.xml",
        "entity.other.attribute-name.js"
      ],
      "settings": {
        "foreground": "#FF7DE9"
      }
    },
    {
      "name": "HTML Comment",
      "scope": "comment.block.html",
      "settings": {
        "foreground": "#86DE74AA"
      }
    },
    {
      "name": "HTML String begin/end",
      "scope": [
        "punctuation.definition.string.begin.html",
        "punctuation.definition.string.end.html"
      ],
      "settings": {
        "foreground": "#939395"
      }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "meta.selector.css",
        "entity.name.tag.css",
        "keyword.control.at-rule.media.css"
      ],
      "settings": {
        "foreground": "#75BFFF"
      }
    },
    {
      "name": "CSS Property values",
      "scope": [
        "meta.function.url.css",
        "meta.property-value.css",
        "support.constant.property-value.css",
        "support.function.url.css",
        "support.function.misc.css",
        "keyword.other.unit.px.css",
        "keyword.other.unit.pt.css",
        "keyword.other.unit.percentage.css",
        "keyword.other.unit.em.css",
        "keyword.other.unit.rem.css",
        "keyword.other.unit.ch.css",
        "keyword.other.unit.vh.css",
        "keyword.other.unit.vw.css",
        "keyword.other.unit.s.css",
        "keyword.other.unit.deg.css",
        "keyword.other.unit.scss",
        "keyword.other.unit.dppx.css",
        "support.constant.media.css",
        "constant.numeric.css",
        "string.quoted.single.css",
        "string.quoted.double.css"
      ],
      "settings": {
        "foreground": "#709AFF"
      }
    },
    {
      "name": "CSS Functions / Hex / Pseudo",
      "scope": [
        "constant.other.color.rgb-value.hex.css",
        "variable.parameter.url.css",
        "support.function.transform.css",
        "support.function.calc.css",
        "entity.other.attribute-name.pseudo-class.css",
        "meta.function.gradient.css",
        "support.function.gradient.css",
        "variable.parameter.url.scss",
        "entity.name.tag.scss"
      ],
      "settings": {
        "foreground": "#E9F4FE"
      }
    },
    {
      "name": "CSS Punctuation",
      "scope": [
        "punctuation.terminator.rule.css",
        "punctuation.separator.key-value.css",
        "punctuation.section.property-list.begin.bracket.curly.css",
        "punctuation.section.property-list.end.bracket.curly.css",
        "punctuation.section.function.begin.bracket.round.css",
        "punctuation.section.function.end.bracket.round.css",
        "punctuation.definition.entity.begin.bracket.square.css",
        "punctuation.definition.entity.end.bracket.square.css",
        "punctuation.separator.list.comma.css",
        "keyword.operator.pattern.css"
      ],
      "settings": {
        "foreground": "#D7D7DB"
      }
    },
    {
      "name": "CSS Property name",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.media.css",
        "support.type.vendored.property-name.media.css"
      ],
      "settings": {
        "foreground": "#86DE74"
      }
    },
    {
      "name": "CSS Vendored / Pseudo-element",
      "scope": [
        "support.type.vendored.property-name.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#939395"
      }
    },
    {
      "name": "CSS Combinator",
      "scope": "keyword.operator.combinator.css",
      "settings": {
        "foreground": "#D7D7DB"
      }
    },
    {
      "name": "JSON Property",
      "scope": "support.type.property-name.json",
      "settings": {
        "foreground": "#75BFFF"
      }
    },
    {
      "name": "JSON String",
      "scope": "string.quoted.double.json",
      "settings": {
        "foreground": "#FF7DE9"
      }
    },
    {
      "name": "JSON Numeric",
      "scope": ["constant.numeric.json", "constant.language.json"],
      "settings": {
        "foreground": "#86DE74"
      }
    },
    {
      "name": "JSON Separators",
      "scope": [
        "punctuation.separator.dictionary.key-value.json",
        "punctuation.separator.dictionary.pair.json"
      ],
      "settings": {
        "foreground": "#B1B1B3"
      }
    },
    {
      "name": "Variable object",
      "scope": "variable.other.object",
      "settings": {
        "foreground": "#B98EFF"
      }
    },
    {
      "name": "Constant property",
      "scope": "variable.other.constant.property",
      "settings": {
        "foreground": "#86DE74"
      }
    },
    {
      "name": "Null / Undefined",
      "scope": ["constant.language.null", "constant.language.undefined"],
      "settings": {
        "foreground": "#939395"
      }
    },
    {
      "name": "Boolean true",
      "scope": "constant.language.boolean.true",
      "settings": {
        "foreground": "#FF7DE9"
      }
    },
    {
      "name": "Boolean false",
      "scope": "constant.language.boolean.false",
      "settings": {
        "foreground": "#FF7DE9"
      }
    },
    {
      "name": "HTML attribute values",
      "scope": [
        "meta.attribute.name",
        "string.quoted.double.html",
        "string.quoted.double.xml"
      ],
      "settings": {
        "foreground": "#B98EFF"
      }
    },
    {
      "name": "Markup heading",
      "scope": "markup.heading",
      "settings": {
        "foreground": "#75BFFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup underline",
      "scope": "markup.underline",
      "settings": {
        "foreground": "#75BFFF",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup bold",
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup italic",
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup inserted",
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#86DE74"
      }
    },
    {
      "name": "Markup deleted",
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#FF0039"
      }
    },
    {
      "name": "Markup changed",
      "scope": "markup.changed",
      "settings": {
        "foreground": "#0A84FF"
      }
    },
    {
      "name": "Markdown quote",
      "scope": "punctuation.definition.quote.begin.markdown",
      "settings": {
        "foreground": "#FF7DE9"
      }
    },
    {
      "name": "Markdown list",
      "scope": "punctuation.definition.list.begin.markdown",
      "settings": {
        "foreground": "#B1B1B3"
      }
    },
    {
      "name": "Markup inline raw",
      "scope": "markup.inline.raw",
      "settings": {
        "foreground": "#B98EFF"
      }
    },
    {
      "name": "Markdown paragraph",
      "scope": "meta.paragraph.markdown",
      "settings": {
        "foreground": "#B1B1B3"
      }
    },
    {
      "name": "Markdown link title",
      "scope": [
        "string.other.link.title.markdown",
        "string.other.link.description.markdown"
      ],
      "settings": {
        "foreground": "#E9F4FE"
      }
    },
    {
      "name": "Markdown link URL",
      "scope": [
        "markup.underline.link.markdown",
        "markup.underline.link.image.markdown"
      ],
      "settings": {
        "foreground": "#75BFFF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Env files",
      "scope": ["source.env", "constant.numeric.env"],
      "settings": {
        "foreground": "#B1B1B3"
      }
    }
  ],
