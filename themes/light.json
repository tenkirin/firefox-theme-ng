{
  "$schema": "vscode://schemas/color-theme",
  "name": "Firefox Light NG",
  "type": "Light",
  "tokenColors": [
    {
      "settings": {
        "foreground": "#15141A"
      }
    },
    {
      "name": "Comment",
      "scope": "comment",
      "settings": {
        "foreground": "#939393"
      }
    },
    {
      "name": "String",
      "scope": "string",
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "Regexp",
      "scope": "string.regexp",
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "Number",
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "Variable language",
      "scope": "variable.language",
      "settings": {
        "foreground": "#8000D7"
      }
    },
    {
      "name": "Variable constant",
      "scope": "variable.other.constant",
      "settings": {
        "foreground": "#0074E8"
      }
    },
    {
      "name": "Keyword",
      "scope": "keyword",
      "settings": {
        "foreground": "#DD00A9"
      }
    },
    {
      "name": "Storage",
      "scope": "storage",
      "settings": {
        "foreground": "#DD00A9"
      }
    },
    {
      "name": "Class name",
      "scope": ["entity.name.class", "entity.name.type"],
      "settings": {
        "foreground": "#0074E8"
      }
    },
    {
      "name": "Function name",
      "scope": "meta.function-call",
      "settings": {
        "foreground": "#8000D7"
      }
    },
    {
      "name": "Function definition",
      "scope": "meta.definition.function",
      "settings": {
        "foreground": "#0074E8"
      }
    },
    {
      "name": "Variable object property",
      "scope": "variable.object.property",
      "settings": {
        "foreground": "#058B00"
      }
    },
    {
      "name": "Embedded code markers",
      "scope": [
        "punctuation.section.embedded.begin",
        "punctuation.section.embedded.end"
      ],
      "settings": {
        "foreground": "#4A4A4F"
      }
    },
    {
      "name": "Built-in constant",
      "scope": ["constant.language", "meta.preprocessor"],
      "settings": {
        "foreground": "#4A4A4F"
      }
    },
    {
      "name": "User-defined constant",
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#8000D7"
      }
    },
    {
      "name": "Inherited class",
      "scope": "entity.other.inherited-class",
      "settings": {
        "fontStyle": "underline",
        "foreground": "#0074E8"
      }
    },
    {
      "name": "Function argument",
      "scope": "variable.parameter",
      "settings": {
        "foreground": "#0074E8"
      }
    },
    {
      "name": "Punctuation accessor",
      "scope": "punctuation.accessor",
      "settings": {
        "foreground": "#4A4A4F"
      }
    },
    {
      "name": "Keyword type",
      "scope": "keyword.type",
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "C# Properties / Functions",
      "scope": ["entity.name.variable.property.cs", "entity.name.function.cs"],
      "settings": {
        "foreground": "#4A4A4F"
      }
    },
    {
      "name": "C# Storage modifier",
      "scope": "storage.modifier.cs",
      "settings": {
        "foreground": "#058B00"
      }
    },
    {
      "name": "C# new keyword",
      "scope": "keyword.other.new.cs",
      "settings": {
        "foreground": "#8000D7"
      }
    },
    {
      "name": "DOCTYPE",
      "scope": "meta.tag.sgml.doctype.html",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#939393"
      }
    },
    {
      "name": "Tag name",
      "scope": "entity.name.tag",
      "settings": {
        "foreground": "#0074E8"
      }
    },
    {
      "name": "Tag start/end",
      "scope": "punctuation.definition.tag",
      "settings": {
        "foreground": "#737373"
      }
    },
    {
      "name": "HTML structure tag",
      "scope": "meta.tag.structure.any.html",
      "settings": {
        "foreground": "#8000D7"
      }
    },
    {
      "name": "Tag attribute",
      "scope": [
        "entity.other.attribute.name",
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.id.html"
      ],
      "settings": {
        "foreground": "#DD00A9"
      }
    },
    {
      "name": "Library function",
      "scope": "support.function",
      "settings": {
        "foreground": "#058B00"
      }
    },
    {
      "name": "Continuation",
      "scope": "punctuation.separator.continuation",
      "settings": {
        "foreground": "#4A4A4F"
      }
    },
    {
      "name": "Library constant",
      "scope": "support.constant",
      "settings": {
        "foreground": "#8000D7"
      }
    },
    {
      "name": "Library class/type",
      "scope": ["support.type", "support.class"],
      "settings": {
        "foreground": "#8000D7"
      }
    },
    {
      "name": "Library variable",
      "scope": "support.other.variable",
      "settings": {
        "foreground": "#5C5C5F"
      }
    },
    {
      "name": "Quoted strings",
      "scope": ["string.quoted.single", "string.quoted.double"],
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "HTML Comment",
      "scope": "comment.block.html",
      "settings": {
        "foreground": "#058B00AA"
      }
    },
    {
      "name": "HTML String delimiters",
      "scope": [
        "punctuation.definition.string.begin.html",
        "punctuation.definition.string.end.html"
      ],
      "settings": {
        "foreground": "#939393"
      }
    },
    {
      "name": "Storage type",
      "scope": "storage.type",
      "settings": {
        "foreground": "#DD00A9"
      }
    },
    {
      "name": "this keyword",
      "scope": "variable.language.this",
      "settings": {
        "foreground": "#DD00A9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Boolean",
      "scope": [
        "constant.language.boolean.true",
        "constant.language.boolean.false"
      ],
      "settings": {
        "foreground": "#DD00A9"
      }
    },
    {
      "name": "JS Operators / undefined",
      "scope": [
        "constant.language.undefined",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic"
      ],
      "settings": {
        "foreground": "#4A4A4F"
      }
    },
    {
      "name": "Properties / Object keys / Functions",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#058B00"
      }
    },
    {
      "name": "Function name style",
      "scope": "entity.name.function",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Object member",
      "scope": "meta.object.member",
      "settings": {
        "foreground": "#8000D7"
      }
    },
    {
      "name": "Variable readwrite",
      "scope": "variable.other.readwrite",
      "settings": {
        "foreground": "#0074E8"
      }
    },
    {
      "name": "Control flow",
      "scope": "keyword.control.flow",
      "settings": {
        "foreground": "#DD00A9"
      }
    },
    {
      "name": "Variable object / Module",
      "scope": ["variable.other.object", "entity.name.type.module"],
      "settings": {
        "foreground": "#8000D7"
      }
    },
    {
      "name": "Braces / Brackets",
      "scope": [
        "meta.brace.square",
        "meta.brace.round",
        "punctuation.definition.block",
        "punctuation.definition.parameters.begin",
        "punctuation.definition.parameters.end"
      ],
      "settings": {
        "foreground": "#4A4A4F"
      }
    },
    {
      "name": "Template string",
      "scope": "string.template",
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "Template expression",
      "scope": "meta.template.expression",
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "Constant property",
      "scope": "variable.other.constant.property",
      "settings": {
        "foreground": "#058B00"
      }
    },
    {
      "name": "JSON Property",
      "scope": "support.type.property-name.json",
      "settings": {
        "foreground": "#0074E8"
      }
    },
    {
      "name": "JSON String",
      "scope": "string.quoted.double.json",
      "settings": {
        "foreground": "#DD00A9"
      }
    },
    {
      "name": "JSON Numeric / Constants",
      "scope": ["constant.language.json", "constant.numeric.json"],
      "settings": {
        "foreground": "#058B00"
      }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "meta.selector.css",
        "entity.name.tag.css",
        "keyword.control.at-rule.media.css"
      ],
      "settings": {
        "foreground": "#8000D7"
      }
    },
    {
      "name": "CSS Property values",
      "scope": [
        "meta.function.url.css",
        "meta.property-value.css",
        "support.constant.property-value.css",
        "support.function.url.css",
        "support.function.misc.css",
        "keyword.other.unit.px.css",
        "keyword.other.unit.pt.css",
        "keyword.other.unit.percentage.css",
        "keyword.other.unit.em.css",
        "keyword.other.unit.rem.css",
        "keyword.other.unit.ch.css",
        "keyword.other.unit.vh.css",
        "keyword.other.unit.vw.css",
        "keyword.other.unit.s.css",
        "keyword.other.unit.deg.css",
        "keyword.other.unit.scss",
        "keyword.other.unit.dppx.css",
        "support.constant.media.css",
        "constant.numeric.css",
        "string.quoted.single.css",
        "string.quoted.double.css"
      ],
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "CSS Functions / Hex / Pseudo",
      "scope": [
        "constant.other.color.rgb-value.hex.css",
        "variable.parameter.url.css",
        "support.function.transform.css",
        "support.function.calc.css",
        "entity.other.attribute-name.pseudo-class.css",
        "meta.function.gradient.css",
        "support.function.gradient.css",
        "variable.parameter.url.scss",
        "entity.name.tag.scss"
      ],
      "settings": {
        "foreground": "#4A4A4F"
      }
    },
    {
      "name": "CSS Punctuation",
      "scope": [
        "punctuation.terminator.rule.css",
        "punctuation.separator.key-value.css",
        "punctuation.section.property-list.begin.bracket.curly.css",
        "punctuation.section.property-list.end.bracket.curly.css",
        "punctuation.section.function.begin.bracket.round.css",
        "punctuation.section.function.end.bracket.round.css",
        "punctuation.definition.entity.begin.bracket.square.css",
        "punctuation.definition.entity.end.bracket.square.css",
        "punctuation.separator.list.comma.css",
        "keyword.operator.pattern.css"
      ],
      "settings": {
        "foreground": "#4A4A4F"
      }
    },
    {
      "name": "CSS Property name",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.media.css",
        "support.type.vendored.property-name.media.css"
      ],
      "settings": {
        "foreground": "#058B00"
      }
    },
    {
      "name": "CSS Vendored / Pseudo-element",
      "scope": [
        "support.type.vendored.property-name.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#5C5C5F"
      }
    },
    {
      "name": "CSS Combinator",
      "scope": "keyword.operator.combinator.css",
      "settings": {
        "foreground": "#4A4A4F"
      }
    },
    {
      "name": "Markup heading",
      "scope": "markup.heading",
      "settings": {
        "foreground": "#0074E8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup underline",
      "scope": "markup.underline",
      "settings": {
        "foreground": "#0074E8",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup bold",
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup italic",
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup inserted",
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#058B00"
      }
    },
    {
      "name": "Markup deleted",
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#A4000F"
      }
    },
    {
      "name": "Markup changed",
      "scope": "markup.changed",
      "settings": {
        "foreground": "#0061E0"
      }
    },
    {
      "name": "Markdown quote",
      "scope": "punctuation.definition.quote.begin.markdown",
      "settings": {
        "foreground": "#DD00A9"
      }
    },
    {
      "name": "Markdown list",
      "scope": "punctuation.definition.list.begin.markdown",
      "settings": {
        "foreground": "#4A4A4F"
      }
    },
    {
      "name": "Markup inline raw",
      "scope": "markup.inline.raw",
      "settings": {
        "foreground": "#058B00"
      }
    },
    {
      "name": "Markdown paragraph",
      "scope": "meta.paragraph.markdown",
      "settings": {
        "foreground": "#4A4A4F"
      }
    },
    {
      "name": "Markdown link title",
      "scope": [
        "string.other.link.title.markdown",
        "string.other.link.description.markdown"
      ],
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "Markdown link URL",
      "scope": [
        "markup.underline.link.markdown",
        "markup.underline.link.image.markdown"
      ],
      "settings": {
        "foreground": "#0061E0",
        "fontStyle": "italic"
      }
    }
  ],
