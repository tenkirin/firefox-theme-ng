{
  "$schema": "vscode://schemas/color-theme",
  "name": "Firefox Light NG",
  "type": "light",
  "tokenColors": [
    {
      "settings": {
        "foreground": "#15141A"
      }
    },
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#5C5C5F88",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment markup link",
      "scope": "comment markup.link",
      "settings": {
        "foreground": "#0060DF"
      }
    },
    {
      "name": "String",
      "scope": "string",
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "String regexp",
      "scope": [
        "string.regexp",
        "constant.character.escape.backslash.regexp",
        "constant.other.character-class.regexp",
        "keyword.operator.quantifier.regexp"
      ],
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "Quoted strings",
      "scope": [
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double"
      ],
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "Template string",
      "scope": "string.template",
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "Template expression",
      "scope": "meta.template.expression",
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "String other link",
      "scope": "string.other.link",
      "settings": {
        "foreground": "#0060DF"
      }
    },
    {
      "name": "String source / embedded",
      "scope": ["string > source", "string embedded"],
      "settings": {
        "foreground": "#38383D"
      }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric", "constant.character.numeric"],
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "Meta / Preprocessor",
      "scope": "meta.preprocessor",
      "settings": {
        "foreground": "#5C5C5F"
      }
    },
    {
      "name": "Null / Undefined",
      "scope": ["constant.language.null", "constant.language.undefined"],
      "settings": {
        "foreground": "#5C5C5F"
      }
    },
    {
      "name": "Boolean",
      "scope": [
        "constant.language.boolean",
        "constant.language.boolean.true",
        "constant.language.boolean.false"
      ],
      "settings": {
        "foreground": "#DD00A9"
      }
    },
    {
      "name": "Language / Support constant",
      "scope": [
        "constant.language",
        "support.constant",
        "support.constant.math",
        "support.constant.meta.property-value",
        "support.constant.vendor.property-value"
      ],
      "settings": {
        "foreground": "#DD00A9"
      }
    },
    {
      "name": "User-defined constant",
      "scope": [
        "constant",
        "constant.character",
        "constant.other",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#8000D7"
      }
    },
    {
      "name": "Color constant",
      "scope": [
        "constant.other.color",
        "constant.other.color.rgb-value.hex.css"
      ],
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "Constant character escape",
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#0074E8"
      }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.language", "variable.interpolation"],
      "settings": {
        "foreground": "#8000D7"
      }
    },
    {
      "name": "Variable constant",
      "scope": ["variable.other.constant", "constant.variable"],
      "settings": {
        "foreground": "#8000D7"
      }
    },
    {
      "name": "Variable readwrite",
      "scope": [
        "variable.other.readwrite",
        "variable.instance",
        "variable.other.instance",
        "variable.readwrite.instance",
        "variable.other.readwrite.instance"
      ],
      "settings": {
        "foreground": "#8000D7"
      }
    },
    {
      "name": "Variable object / Module",
      "scope": ["variable.other.object", "entity.name.type.module"],
      "settings": {
        "foreground": "#8000D7"
      }
    },
    {
      "name": "Variable parameter",
      "scope": [
        "variable.parameter",
        "variable.parameter.function",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#0074E8"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.other.new",
        "keyword.other.debugger",
        "keyword.other.special-method"
      ],
      "settings": {
        "foreground": "#DD00A9"
      }
    },
    {
      "name": "Keyword operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.bitwise",
        "keyword.operator.increment",
        "keyword.operator.relational",
        "keyword.operator.ternary",
        "keyword.control.operator"
      ],
      "settings": {
        "foreground": "#38383D"
      }
    },
    {
      "name": "Expression keyword",
      "scope": [
        "keyword.operator.expression",
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.void",
        "keyword.operator.instanceof",
        "keyword.operator.expression.in",
        "keyword.operator.type"
      ],
      "settings": {
        "foreground": "#DD00A9"
      }
    },
    {
      "name": "Keyword control flow",
      "scope": [
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.at-rule.media.css"
      ],
      "settings": {
        "foreground": "#DD00A9"
      }
    },
    {
      "name": "Keyword type",
      "scope": "keyword.type",
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "Storage",
      "scope": "storage",
      "settings": {
        "foreground": "#DD00A9"
      }
    },
    {
      "name": "Storage type",
      "scope": [
        "storage.type",
        "storage.modifier.import",
        "storage.modifier.package",
        "storage.type.annotation",
        "storage.type.primitive"
      ],
      "settings": {
        "foreground": "#DD00A9"
      }
    },
    {
      "name": "Arrow function",
      "scope": "storage.type.function.arrow",
      "settings": {
        "foreground": "#38383D"
      }
    },
    {
      "name": "Class name",
      "scope": ["entity.name.class", "entity.name.type"],
      "settings": {
        "foreground": "#0074E8"
      }
    },
    {
      "name": "Class types",
      "scope": ["entity.name.type.class", "support.class"],
      "settings": {
        "foreground": "#0074E8"
      }
    },
    {
      "name": "Inherited class",
      "scope": "entity.other.inherited-class",
      "settings": {
        "fontStyle": "underline",
        "foreground": "#0074E8"
      }
    },
    {
      "name": "Function name",
      "scope": "entity.name.function",
      "settings": {
        "foreground": "#058B00",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function call",
      "scope": [
        "meta.function-call",
        "meta.method-call",
        "meta.method",
        "variable.function"
      ],
      "settings": {
        "foreground": "#8000D7"
      }
    },
    {
      "name": "Function definition",
      "scope": "meta.definition.function",
      "settings": {
        "foreground": "#0074E8"
      }
    },
    {
      "name": "Support function",
      "scope": ["support.function", "support.function.any-method"],
      "settings": {
        "foreground": "#058B00"
      }
    },
    {
      "name": "Support constant",
      "scope": "support.constant",
      "settings": {
        "foreground": "#DD00A9"
      }
    },
    {
      "name": "Support class/type",
      "scope": ["support.type", "support.class"],
      "settings": {
        "foreground": "#0074E8"
      }
    },
    {
      "name": "Support variable",
      "scope": [
        "support.other.variable",
        "support.variable",
        "support.variable.dom"
      ],
      "settings": {
        "foreground": "#DD00A9"
      }
    },
    {
      "name": "Property / Object keys",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "support.variable.property",
        "support.variable.property.dom",
        "support.type.property-name",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#058B00"
      }
    },
    {
      "name": "Constant property",
      "scope": "variable.other.constant.property",
      "settings": {
        "foreground": "#058B00"
      }
    },
    {
      "name": "Object member",
      "scope": "meta.object.member",
      "settings": {
        "foreground": "#8000D7"
      }
    },
    {
      "name": "Meta class",
      "scope": "meta.class",
      "settings": {
        "foreground": "#0074E8"
      }
    },
    {
      "name": "Meta class body",
      "scope": "meta.class.body",
      "settings": {
        "foreground": "#15141A"
      }
    },
    {
      "name": "Meta require",
      "scope": "meta.require",
      "settings": {
        "foreground": "#0074E8"
      }
    },
    {
      "name": "Meta separator",
      "scope": "meta.separator",
      "settings": {
        "foreground": "#38383D"
      }
    },
    {
      "name": "Meta tag",
      "scope": "meta.tag",
      "settings": {
        "foreground": "#38383D"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.delimiter.period",
        "meta.brace.round",
        "meta.brace.square",
        "meta.brace",
        "meta.array",
        "punctuation.accessor",
        "punctuation.definition.arguments",
        "punctuation.definition.array",
        "punctuation.definition.block",
        "punctuation.definition.function-parameters",
        "punctuation.definition.method-parameters",
        "punctuation.definition.parameters",
        "punctuation.definition.parameters.begin",
        "punctuation.definition.parameters.end",
        "punctuation.definition.separator",
        "punctuation.separator.comma",
        "punctuation.separator.arguments",
        "punctuation.separator.key-value",
        "punctuation.separator.continuation",
        "punctuation.section.array",
        "punctuation.terminator.expression",
        "punctuation.terminator.statement"
      ],
      "settings": {
        "foreground": "#38383D"
      }
    },
    {
      "name": "Punctuation heading / identity",
      "scope": [
        "punctuation.definition.heading",
        "punctuation.definition.identity"
      ],
      "settings": {
        "foreground": "#0074E8"
      }
    },
    {
      "name": "Punctuation definition bold",
      "scope": "punctuation.definition.bold",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#0074E8"
      }
    },
    {
      "name": "Punctuation definition italic",
      "scope": "punctuation.definition.italic",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#0074E8"
      }
    },
    {
      "name": "Punctuation section class / method",
      "scope": [
        "punctuation.section.method",
        "punctuation.section.class",
        "punctuation.section.inner-class"
      ],
      "settings": {
        "foreground": "#38383D"
      }
    },
    {
      "name": "Embedded code markers",
      "scope": [
        "punctuation.section.embedded.begin",
        "punctuation.section.embedded.end"
      ],
      "settings": {
        "foreground": "#5C5C5F"
      }
    },
    {
      "name": "this keyword",
      "scope": "variable.language.this",
      "settings": {
        "foreground": "#DD00A9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "super keyword",
      "scope": "variable.language.super",
      "settings": {
        "foreground": "#DD00A9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Decorator",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#DD00A9"
      }
    },
    {
      "name": "Tag name",
      "scope": ["entity.name.tag", "entity.name.tag.custom"],
      "settings": {
        "foreground": "#0074E8"
      }
    },
    {
      "name": "Tag start/end",
      "scope": "punctuation.definition.tag",
      "settings": {
        "foreground": "#0074E8"
      }
    },
    {
      "name": "DOCTYPE",
      "scope": [
        "entity.name.tag.doctype",
        "meta.tag.sgml.doctype",
        "meta.tag.metadata.doctype.html",
        "meta.tag.sgml.doctype.html"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#5C5C5F"
      }
    },
    {
      "name": "HTML structure tag",
      "scope": "meta.tag.structure.any.html",
      "settings": {
        "foreground": "#8000D7"
      }
    },
    {
      "name": "Tag attribute",
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.id",
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.id.html",
        "entity.other.attribute-name.localname.xml",
        "entity.other.attribute-name.js"
      ],
      "settings": {
        "foreground": "#DD00A9"
      }
    },
    {
      "name": "HTML Comment",
      "scope": "comment.block.html",
      "settings": {
        "foreground": "#5C5C5F88"
      }
    },
    {
      "name": "String delimiters",
      "scope": [
        "punctuation.definition.string",
        "punctuation.definition.string.begin.html",
        "punctuation.definition.string.end.html",
        "punctuation.definition.string.begin.markdown",
        "punctuation.definition.string.end.markdown"
      ],
      "settings": {
        "foreground": "#5C5C5F"
      }
    },
    {
      "name": "HTML/XML attribute values",
      "scope": [
        "string.quoted.single.html",
        "string.quoted.double.html",
        "string.quoted.single.xml",
        "string.quoted.double.xml"
      ],
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "meta.selector",
        "meta.selector.css",
        "entity.name.tag.css",
        "entity.name.tag.scss"
      ],
      "settings": {
        "foreground": "#0074E8"
      }
    },
    {
      "name": "CSS Property values",
      "scope": [
        "meta.function.url.css",
        "meta.property-value.css",
        "support.constant.property-value.css",
        "variable.parameter.url.css",
        "keyword.other.unit",
        "keyword.other.unit.px.css",
        "keyword.other.unit.pt.css",
        "keyword.other.unit.percentage.css",
        "keyword.other.unit.em.css",
        "keyword.other.unit.rem.css",
        "keyword.other.unit.ch.css",
        "keyword.other.unit.vh.css",
        "keyword.other.unit.vw.css",
        "keyword.other.unit.s.css",
        "keyword.other.unit.deg.css",
        "keyword.other.unit.scss",
        "keyword.other.unit.dppx.css",
        "support.constant.media.css",
        "constant.numeric.css",
        "string.quoted.single.css",
        "string.quoted.double.css"
      ],
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "CSS URL / Hex values",
      "scope": [
        "constant.other.color.rgb-value.hex.css",
        "constant.other.color",
        "variable.parameter.url.css"
      ],
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "CSS Functions",
      "scope": [
        "support.function.url.css",
        "support.function.misc.css",
        "support.function.transform.css",
        "support.function.calc.css",
        "meta.function.gradient.css",
        "support.function.gradient.css"
      ],
      "settings": {
        "foreground": "#058B00"
      }
    },
    {
      "name": "CSS Punctuation",
      "scope": [
        "punctuation.terminator.rule.css",
        "punctuation.separator.key-value.css",
        "punctuation.section.property-list.begin.bracket.curly.css",
        "punctuation.section.property-list.end.bracket.curly.css",
        "punctuation.section.function.begin.bracket.round.css",
        "punctuation.section.function.end.bracket.round.css",
        "punctuation.definition.entity.begin.bracket.square.css",
        "punctuation.definition.entity.end.bracket.square.css",
        "punctuation.separator.list.comma.css",
        "keyword.operator.pattern.css"
      ],
      "settings": {
        "foreground": "#38383D"
      }
    },
    {
      "name": "CSS Property name",
      "scope": [
        "support.type.vendor.property-name",
        "support.type.property-name.css",
        "support.type.vendored.property-name.css",
        "support.type.property-name.media.css",
        "support.type.vendored.property-name.media.css"
      ],
      "settings": {
        "foreground": "#058B00"
      }
    },
    {
      "name": "CSS Pseudo selector",
      "scope": [
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#DD00A9"
      }
    },
    {
      "name": "CSS Combinator",
      "scope": "keyword.operator.combinator.css",
      "settings": {
        "foreground": "#38383D"
      }
    },
    {
      "name": "CSS/SCSS/Sass variable",
      "scope": [
        "variable.css",
        "variable.scss",
        "variable.sass",
        "variable.parameter.url.scss",
        "variable.parameter.url.sass"
      ],
      "settings": {
        "foreground": "#8000D7"
      }
    },
    {
      "name": "JSON Property",
      "scope": "support.type.property-name.json",
      "settings": {
        "foreground": "#058B00"
      }
    },
    {
      "name": "JSON String",
      "scope": "string.quoted.double.json",
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "JSON Number",
      "scope": "constant.numeric.json",
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "JSON Constants",
      "scope": "constant.language.json",
      "settings": {
        "foreground": "#DD00A9"
      }
    },
    {
      "name": "JSON Separators",
      "scope": [
        "punctuation.separator.dictionary.key-value.json",
        "punctuation.separator.dictionary.pair.json"
      ],
      "settings": {
        "foreground": "#38383D"
      }
    },
    {
      "name": "Markup heading",
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "entity.name.section",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#0074E8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup underline",
      "scope": "markup.underline",
      "settings": {
        "foreground": "#0074E8",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup bold",
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup italic",
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup inserted",
      "scope": ["markup.inserted", "markup.inserted.diff"],
      "settings": {
        "foreground": "#058B00"
      }
    },
    {
      "name": "Markup deleted",
      "scope": ["markup.deleted", "markup.deleted.diff"],
      "settings": {
        "foreground": "#A4000F"
      }
    },
    {
      "name": "Markup changed",
      "scope": "markup.changed",
      "settings": {
        "foreground": "#0074E8"
      }
    },
    {
      "name": "Markup link",
      "scope": [
        "meta.link",
        "meta.link.inline.markdown",
        "markup.link",
        "markup.underline.link",
        "markup.underline.link.image"
      ],
      "settings": {
        "foreground": "#0060DF"
      }
    },
    {
      "name": "Diff header",
      "scope": [
        "meta.diff.header.from-file",
        "meta.diff.header.to-file",
        "meta.diff.header.git"
      ],
      "settings": {
        "foreground": "#5C5C5F"
      }
    },
    {
      "name": "Markup quote",
      "scope": ["markup.quote", "markup.quote.markdown"],
      "settings": {
        "foreground": "#058B00",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup raw",
      "scope": ["markup.raw", "markup.raw.block.markdown"],
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "Markup inline raw",
      "scope": [
        "markup.inline.raw",
        "markup.inline.raw.markdown",
        "markup.inline.raw.string.markdown"
      ],
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "Markdown quote",
      "scope": "punctuation.definition.quote.begin.markdown",
      "settings": {
        "foreground": "#DD00A9"
      }
    },
    {
      "name": "Markdown list",
      "scope": [
        "punctuation.definition.list",
        "punctuation.definition.list.begin",
        "punctuation.definition.list.begin.markdown",
        "punctuation.definition.list.end"
      ],
      "settings": {
        "foreground": "#38383D"
      }
    },
    {
      "name": "Markdown paragraph",
      "scope": "meta.paragraph.markdown",
      "settings": {
        "foreground": "#15141A"
      }
    },
    {
      "name": "Markdown link title",
      "scope": [
        "string.other.link.title.markdown",
        "string.other.link.description.markdown"
      ],
      "settings": {
        "foreground": "#003EAA"
      }
    },
    {
      "name": "Markdown link URL",
      "scope": [
        "markup.underline.link.markdown",
        "markup.underline.link.image.markdown"
      ],
      "settings": {
        "foreground": "#0060DF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown heading marker",
      "scope": "punctuation.definition.heading.markdown",
      "settings": {
        "foreground": "#0074E8",
